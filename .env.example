# === Required ===
DATABASE_URL=postgresql://private_ai:private_ai@localhost:5432/private_ai
S3_BUCKET=private-ai
S3_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
SECRET_KEY=dev-secret-key-change-in-production

# At least one model API key is required
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# === Auth ===
# AUTH_MODE=dev uses a simple email login (no SSO). Set to "sso" for production.
AUTH_MODE=dev
DEV_USER_EMAIL=dev@localhost

# === SSO (required when AUTH_MODE=sso) ===
# AUTH_CLIENT_ID=
# AUTH_CLIENT_SECRET=
# AUTH_ISSUER_URL=

# === Optional ===
FLASK_APP=app:create_app
FLASK_DEBUG=1
